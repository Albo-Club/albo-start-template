# ============================================================================
# Albo Start Template — environment variables
#
# Copy this file to .env.local. Most values are filled automatically by
# `scripts/albo-create.sh`. The keys you might want to fill manually are
# marked with [USER ACTION].
#
# All Convex-only secrets MUST also be set on the Convex deployment via
# `pnpm exec convex env set <KEY> <VALUE>` — `albo-fix-env.sh` does this.
# ============================================================================

# --- Convex deployment (auto-filled by `convex dev`) -------------------------

CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# --- App identity ------------------------------------------------------------

APP_NAME="Albo Start Template"
APP_DEPLOYMENT_ENV=development
SITE_URL=http://localhost:3000

# --- Better Auth (auto-generated by `pnpm setup:env`) ------------------------

BETTER_AUTH_SECRET=
BETTER_AUTH_SECRETS=
BETTER_AUTH_URL=http://localhost:3000
AUTH_PROXY_SHARED_SECRET=

# --- JWKS (auto-synced by `pnpm convex:jwks:sync`) --------------------------
# Don't set manually — let the bootstrap script do it.
# JWKS=

# --- Resend (email delivery) -------------------------------------------------
# [USER ACTION] Get a free key at https://resend.com (3000 emails/month free)
RESEND_API_KEY=
# Mode "test" (default) — Resend's verified test domain, works for any account
RESEND_EMAIL_SENDER=onboarding@resend.dev
# Mode "Albo" — uncomment if your DNS is set on alboteam.com:
# RESEND_EMAIL_SENDER=noreply@alboteam.com

# --- Anthropic (AI chat) -----------------------------------------------------
# [USER ACTION] Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- OpenRouter (alternative AI provider, optional) --------------------------
# [USER ACTION] Get a key at https://openrouter.ai if you prefer OpenRouter
# OPENROUTER_API_KEY=

# --- Sentry (error monitoring, optional) -------------------------------------
# [USER ACTION] Get DSN at https://sentry.io
# VITE_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# --- Storage backend ---------------------------------------------------------
# 'convex' (default — no extra setup) | 's3-primary' | 's3-mirror'
FILE_STORAGE_BACKEND=convex

# --- E2E test auth (only enable on dev / never on prod) ---------------------
# Uncomment + run `pnpm setup:e2e` if you need authenticated Playwright tests.
# ENABLE_E2E_TEST_AUTH=true
# E2E_TEST_SECRET=
# E2E_USER_EMAIL=e2e-user@local.test
# E2E_USER_PASSWORD=
# E2E_ADMIN_EMAIL=e2e-admin@local.test
# E2E_ADMIN_PASSWORD=
